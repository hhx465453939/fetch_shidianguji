### 内存管理
```python
def fetch_book(self, book_title=None):
    """获取整本书的内容"""
    chapters_data = []
    
    try:
        # ... 获取逻辑
        return self.save_to_markdown(chapters_data, book_title)
    finally:
        # 清理资源
        chapters_data.clear()
        if hasattr(self, 'session'):
            self.session.close()
