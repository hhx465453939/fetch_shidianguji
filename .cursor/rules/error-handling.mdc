## 网络请求错误处理

### 重试机制
```python
def safe_request(self, url, max_retries=3, delay=1):
    """安全的网络请求，带重试机制"""
    for attempt in range(max_retries):
        try:
            response = self.session.get(url, timeout=30)
            response.raise_for_status()
            return response
        except requests.exceptions.RequestException as e:
            if attempt == max_retries - 1:
                print(f"请求失败，已重试 {max_retries} 次: {e}")
                raise
            else:
                print(f"请求失败，{delay}秒后重试 (尝试 {attempt + 1}/{max_retries}): {e}")
                time.sleep(delay)
                delay *= 2  # 指数退避
```

### 超时处理
```python
# 设置合理的超时时间
response = self.session.get(url, timeout=30)

# 分别设置连接和读取超时
response = self.session.get(url, timeout=(10, 30))  # (连接超时, 读取超时)
```

## 数据验证

### 输入验证
```python
def extract_book_id_from_url(self, url):
    """从URL中提取书籍ID"""
    if not url:
        return None
    
    if not isinstance(url, str):
        print("错误: URL必须是字符串")
        return None
    
    # 验证URL格式
    if not url.startswith('http'):
        print("错误: URL必须以http开头")
        return None
    
    match = re.search(r'/book/([^/]+)/', url)
    if match:
        return match.group(1)
    return None
```

### 内容验证
```python
def get_chapter_content(self, url, title):
    """获取章节内容"""
    # ... 获取内容逻辑
    
    # 验证内容质量
    if len(content.strip()) < 10:
        print(f"  警告: {title} 内容为空或过短")
        return ""
    
    # 检查内容是否包含有效信息
    if not any(keyword in content for keyword in ['皇极经世', '发音', '收音', '闭音']):
        print(f"  警告: {title} 内容可能不相关")
        return ""
    
    return content
```

