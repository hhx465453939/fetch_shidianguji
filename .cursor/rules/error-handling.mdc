### 进度跟踪
```python
def print_progress(current, total, prefix="进度"):
    """打印进度信息"""
    percentage = (current / total) * 100 if total > 0 else 0
    print(f"{prefix}: {current}/{total} ({percentage:.1f}%)")
```

### 错误统计
```python
class ErrorTracker:
    def __init__(self):
        self.errors = []
        self.warnings = []
    
    def add_error(self, message, context=None):
        self.errors.append({
            'message': message,
            'context': context,
            'timestamp': time.time()
        })
    
    def add_warning(self, message, context=None):
        self.warnings.append({
            'message': message,
            'context': context,
            'timestamp': time.time()
        })
    
    def get_summary(self):
        return {
            'error_count': len(self.errors),
            'warning_count': len(self.warnings),
            'errors': self.errors,
            'warnings': self.warnings
        }
```