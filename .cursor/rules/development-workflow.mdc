def validate_input(url, title):
    """验证用户输入"""
    if not url or not isinstance(url, str):
        raise ValueError("URL不能为空且必须是字符串")
    
    if not validate_url(url):
        raise ValueError("URL格式不正确")
    
    if title and len(title) > 200:
        raise ValueError("标题长度不能超过200字符")
```

