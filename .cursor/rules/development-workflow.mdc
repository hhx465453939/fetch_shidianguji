### 2. 构建脚本
```python
# build.py
import os
import shutil
import subprocess
from pathlib import Path

def build_project():
    """构建项目"""
    print("开始构建项目...")
    
    # 清理旧文件
    clean_directories = ['build', 'dist', '*.egg-info']
    for pattern in clean_directories:
        for path in Path('.').glob(pattern):
            if path.is_dir():
                shutil.rmtree(path)
    
    # 运行测试
    print("运行测试...")
    result = subprocess.run(['pytest', 'tests/'], capture_output=True, text=True)
    if result.returncode != 0:
        print("测试失败，构建中止")
        return False
    
    # 构建包
    print("构建包...")
    subprocess.run(['python', 'setup.py', 'sdist', 'bdist_wheel'])
    
    print("构建完成！")
    return True

if __name__ == "__main__":
    build_project()
```

