## 元数据管理

### 古籍元数据
```python
def extract_ancient_metadata(self, content):
    """提取古籍元数据"""
    metadata = {
        'title': '',
        'author': '',
        'dynasty': '',
        'category': '',
        'total_chapters': 0,
        'total_characters': 0
    }
    
    # 提取标题（通常在开头）
    lines = content.split('\n')
    for line in lines[:10]:  # 只检查前10行
        line = line.strip()
        if line and len(line) < 50:  # 标题通常不会太长
            metadata['title'] = line
            break
    
    # 统计字符数
    metadata['total_characters'] = len(content)
    
    # 统计章节数
    chapter_count = len(re.findall(r'^## \d+\.', content, re.MULTILINE))
    metadata['total_chapters'] = chapter_count
    
    return metadata
```

### 保存元数据
```python
def save_metadata(self, metadata, filepath):
    """保存元数据到JSON文件"""
    metadata_file = filepath.replace('.md', '_metadata.json')
    
    try:
        with open(metadata_file, 'w', encoding='utf-8') as f:
            json.dump(metadata, f, ensure_ascii=False, indent=2)
        print(f"元数据已保存到: {metadata_file}")
    except Exception as e:
        print(f"保存元数据失败: {e}")
```

## 内容统计

### 古籍内容统计
```python
def generate_content_statistics(self, chapters_data):
    """生成内容统计信息"""
    stats = {
        'total_chapters': len(chapters_data),
        'total_characters': 0,
        'total_words': 0,
        'average_chapter_length': 0,
        'longest_chapter': '',
        'shortest_chapter': '',
        'chapter_lengths': []
    }
    
    if not chapters_data:
        return stats
    
    for chapter in chapters_data:
        content = chapter['content']
        char_count = len(content)
        word_count = len(content.split())
        
        stats['total_characters'] += char_count
        stats['total_words'] += word_count
        stats['chapter_lengths'].append({
            'title': chapter['title'],
            'characters': char_count,
            'words': word_count
        })
    
    # 计算平均值
    stats['average_chapter_length'] = stats['total_characters'] // len(chapters_data)
    
    # 找出最长和最短章节
    if stats['chapter_lengths']:
        longest = max(stats['chapter_lengths'], key=lambda x: x['characters'])
        shortest = min(stats['chapter_lengths'], key=lambda x: x['characters'])
        stats['longest_chapter'] = longest['title']
        stats['shortest_chapter'] = shortest['title']
    
    return stats
```