### 古籍特殊格式处理
```python
def format_ancient_text(self, content):
    """格式化古籍文本"""
    lines = content.split('\n')
    formatted_lines = []
    
    for line in lines:
        line = line.strip()
        if not line:
            continue
        
        # 处理古籍特有的换行
        if self._is_ancient_verse(line):
            # 诗词格式，保持原有换行
            formatted_lines.append(line)
        elif self._is_ancient_paragraph(line):
            # 段落格式，添加适当间距
            formatted_lines.append(f"\n{line}\n")
        else:
            # 普通文本
            formatted_lines.append(line)
    
    return '\n'.join(formatted_lines)

def _is_ancient_verse(self, line):
    """判断是否为诗词格式"""
    # 检查是否包含诗词特征
    verse_patterns = [
        r'^.{5,7}$',  # 五言或七言
        r'^.*[，。]$',  # 以标点结尾
        r'^.*[平仄]$',  # 包含平仄标记
    ]
    
    for pattern in verse_patterns:
        if re.match(pattern, line):
            return True
    return False

def _is_ancient_paragraph(self, line):
    """判断是否为段落格式"""
    # 检查段落特征
    if len(line) > 20:  # 较长的文本
        return True
    if re.search(r'[。！？]$', line):  # 以句号等结尾
        return True
    return False
```

## 内容验证

### 古籍内容质量检查
```python
def validate_ancient_content(self, content, title):
    """验证古籍内容质量"""
    issues = []
    
    # 检查内容长度
    if len(content.strip()) < 10:
        issues.append(f"内容过短: {title}")
    
    # 检查是否包含古籍关键词
    ancient_keywords = ['皇极经世', '发音', '收音', '闭音', '卷', '章', '篇']
    if not any(keyword in content for keyword in ancient_keywords):
        issues.append(f"内容可能不相关: {title}")
    
    # 检查是否包含现代内容
    modern_keywords = ['登录', '注册', '版权', '网站', '链接']
    if any(keyword in content for keyword in modern_keywords):
        issues.append(f"包含现代内容: {title}")
    
    # 检查编码问题
    try:
        content.encode('utf-8')
    except UnicodeEncodeError:
        issues.append(f"编码问题: {title}")
    
    return issues
```

### 重复内容检测
```python
def detect_duplicate_content(self, chapters_data):
    """检测重复内容"""
    duplicates = []
    content_hashes = {}
    
    for i, chapter in enumerate(chapters_data):
        content = chapter['content']
        # 使用内容哈希检测重复
        content_hash = hash(content.strip())
        
        if content_hash in content_hashes:
            duplicates.append({
                'index': i,
                'title': chapter['title'],
                'duplicate_of': content_hashes[content_hash]['index'],
                'duplicate_title': content_hashes[content_hash]['title']
            })
        else:
            content_hashes[content_hash] = {
                'index': i,
                'title': chapter['title']
            }
    
    return duplicates
```

## 文件命名规范

### 古籍文件命名
```python
def generate_ancient_filename(self, book_title, timestamp=None):
    """生成古籍文件名"""
    if timestamp is None:
        timestamp = time.strftime("%Y%m%d_%H%M%S")
    
    # 清理书名中的特殊字符
    clean_title = re.sub(r'[<>:"/\\|?*]', '_', book_title)
    clean_title = clean_title.replace(' ', '_')
    
    # 限制长度
    if len(clean_title) > 50:
        clean_title = clean_title[:50]
    
    return f"{clean_title}_{timestamp}.md"
```

